#!/usr/bin/env bash

# See: https://gist.github.com/angelo-v/e0208a18d455e2e6ea3c40ad637aac53
echo 'header:'
jq -R 'gsub("-";"+") | gsub("_";"/") | split(".") | .[0] | @base64d | fromjson' <<< $1
echo -e '\npayload:'
jq -R 'gsub("-";"+") | gsub("_";"/") | split(".") | .[1] | @base64d | fromjson' <<< $1
